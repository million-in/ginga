{
  "name": "ginga",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Ginga desktop shell for the Zig image pipeline.",
  "packageManager": "bun@1.3.11",
  "main": "electron/dist/main.js",
  "scripts": {
    "build": "bash scripts/build-zig.sh all",
    "build:engine": "bash scripts/build-zig.sh",
    "install:global": "bash scripts/install-global.sh",
    "desktop:build": "bun scripts/desktop-check.ts build",
    "build:desktop": "bun run desktop:build",
    "start": "bun run build && bunx electron .",
    "dev": "bun run build && bunx electron .",
    "preview": "bun scripts/electron-bridge.ts preview",
    "check": "bun scripts/desktop-check.ts check"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "electron": ">=30.0.0 <40.0.0"
  }
}
